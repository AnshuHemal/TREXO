// ─────────────────────────────────────────────────────────────────────────────
// Trexo — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth core tables ──────────────────────────────────────────────────
// Required by Better Auth. Do NOT rename these models or their fields.
// Ref: https://better-auth.com/docs/concepts/database

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  /// User's preferred color theme. "system" follows OS preference.
  theme         String    @default("system") // "light" | "dark" | "system"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── App relations ──────────────────────────────────────────────────────────
  sessions      Session[]
  accounts      Account[]

  workspaceMembers WorkspaceMember[]
  assignedIssues   Issue[]           @relation("IssueAssignee")
  reportedIssues   Issue[]           @relation("IssueReporter")
  comments         Comment[]
  activities       Activity[]
  notifications    Notification[]    @relation("NotificationRecipient")
  sentNotifications Notification[]   @relation("NotificationActor")
  notificationPreference NotificationPreference?
  projectMembers   ProjectMember[]
  savedFilters     SavedFilter[]
  projectMutes     ProjectNotificationMute[]
  commentReactions CommentReaction[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verifications")
}

// ─── Trexo app models ─────────────────────────────────────────────────────────

// ── Workspace ─────────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  projects Project[]
  templates IssueTemplate[]
  savedFilters SavedFilter[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole   @default(MEMBER)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ── Project ───────────────────────────────────────────────────────────────────

model Project {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  key         String          // e.g. "TRX" — used to generate issue keys like TRX-42
  description String?
  icon        String?
  visibility  ProjectVisibility @default(PUBLIC)
  /// Per-project workflow config stored as JSON.
  /// Shape: { statuses: { value, label, order }[], transitions?: { from, to }[] }
  /// null = use global defaults from issue-config.tsx
  workflowConfig Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues    Issue[]
  sprints   Sprint[]
  members   ProjectMember[]
  savedFilters SavedFilter[]
  notificationMutes ProjectNotificationMute[]

  @@unique([workspaceId, key])
  @@map("projects")
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum ProjectRole {
  LEAD
  MEMBER
  VIEWER
}

// ── Sprint ────────────────────────────────────────────────────────────────────

model Sprint {
  id        String       @id @default(cuid())
  projectId String
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@map("sprints")
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

// ── Issue ─────────────────────────────────────────────────────────────────────

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  sprintId    String?
  parentId    String?       // sub-task support (one level deep)
  key         Int           // auto-incremented per project (e.g. 42 → "TRX-42")
  title       String
  description String?       // rich text (Tiptap JSON stored as string)
  type        IssueType     @default(TASK)
  status      IssueStatus   @default(TODO)
  priority    IssuePriority @default(MEDIUM)
  position    Float         @default(0) // LexoRank-style ordering on the board
  dueDate     DateTime?
  estimate    Int?          // story points (1-13 fibonacci or t-shirt: 1=XS,2=S,3=M,5=L,8=XL,13=XXL)
  assigneeId  String?
  reporterId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint     Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent     Issue?    @relation("SubTasks", fields: [parentId], references: [id], onDelete: SetNull)
  subTasks   Issue[]   @relation("SubTasks")
  assignee   User?     @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter   User      @relation("IssueReporter", fields: [reporterId], references: [id])
  comments   Comment[]
  activities Activity[]
  labels     IssueLabel[]
  notifications Notification[]

  // Issue links (outgoing: this issue is the source)
  outgoingLinks IssueLink[] @relation("LinkSource")
  // Issue links (incoming: this issue is the target)
  incomingLinks IssueLink[] @relation("LinkTarget")

  @@unique([projectId, key])
  @@map("issues")
}

enum IssueType {
  EPIC
  STORY
  TASK
  BUG
  SUBTASK
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum IssuePriority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NO_PRIORITY
}

// ── Label ─────────────────────────────────────────────────────────────────────

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  issues IssueLabel[]

  @@map("labels")
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("issue_labels")
}

// ── Comment ───────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String   // rich text (Tiptap JSON)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue     Issue             @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  @@map("comments")
}

// ── CommentReaction ───────────────────────────────────────────────────────────

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String   // e.g. "👍", "✅", "🎉", "❤️", "🚀"
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

// ── Activity (audit log) ──────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  issueId   String
  actorId   String
  type      String   // e.g. "status_changed", "assignee_changed", "comment_added"
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ── Notification ──────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "assigned" | "status_changed" | "comment_added" | "mentioned"
  issueId   String?
  actorId   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User   @relation("NotificationRecipient", fields: [userId],  references: [id], onDelete: Cascade)
  issue Issue? @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User   @relation("NotificationActor",     fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ── NotificationPreference ────────────────────────────────────────────────────

model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @unique
  assigned       Boolean @default(true)
  mentioned      Boolean @default(true)
  statusChanged  Boolean @default(true)
  commentAdded   Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ── IssueLink ─────────────────────────────────────────────────────────────────

model IssueLink {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  type      LinkType
  createdAt DateTime @default(now())

  source Issue @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Issue @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@map("issue_links")
}

enum LinkType {
  BLOCKS
  BLOCKED_BY
  DUPLICATES
  RELATES_TO
}

// ── SavedFilter ───────────────────────────────────────────────────────────────

model SavedFilter {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  userId      String
  name        String
  filters     Json     // { search?, sortKey?, groupBy?, dueDateFilter?, assigneeId?, priority?, status? }
  isShared    Boolean  @default(false) // share with whole workspace
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)

  @@unique([projectId, userId, name])
  @@index([projectId, userId])
  @@index([projectId, isShared])
  @@map("saved_filters")
}

// ── IssueTemplate ─────────────────────────────────────────────────────────────

model IssueTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  type        IssueType     @default(TASK)
  priority    IssuePriority @default(MEDIUM)
  titlePrefix String?       // e.g. "[BUG] " — prepended to the title field
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@map("issue_templates")
}

// ── ProjectNotificationMute ───────────────────────────────────────────────────
// When a record exists for (userId, projectId), the user has muted all
// notifications from that project.

model ProjectNotificationMute {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_notification_mutes")
}
